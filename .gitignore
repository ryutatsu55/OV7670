# Quartus compilation database (regenerated on every compile)
db/
incremental_db/

# Compilation outputs (regenerated on every compile)
output_files/

# Temporary files
greybox_tmp/

# Simulation output
simulation/

# PLL simulation files (not needed for Quartus synthesis)
src/pll/*_sim/
src/pll/*_sim.f

# Quartus backup files
*.bak

# Workspace / window layout
*.qws

# IP regeneration reports
*.ipregen.rpt
pll_25.xml
pll_5.xml

# Auto-generated SDC / pin files
*.out.sdc
*_PinBackup.csv

# Auto-generated pin defaults
*_assignment_defaults.qdf

# Project instructions (local only)
CLAUDE.md

# Platform Designer editor cache/scratch state (regenerated on every open)
.qsys_edit/

# HPS Fitter/Assembler outputs (regenerated on every compile, like output_files/)
hps_isw_handoff/
hps_sdram_p0_summary.csv

# Platform Designer board-preset reference data (copied from Terasic GHRD,
# used only by the pin-mux preset picker UI, not required to build)
hps_common_board_info.xml
soc_system_board_info.xml

# Component Editor backup file
*_hw.tcl~
