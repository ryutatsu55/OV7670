module diff_stage (
    input  wire        pclk,
    input  wire        rst_n,

    // capture_gray から来る現在画素
    input  wire [18:0] cap_addr,
    input  wire [7:0]  cap_data,
    input  wire        cap_we,

    // prev_data_ram から読んだ前フレーム画素
    input  wire [7:0]  prev_q,

    // 現在画像BRAMへそのまま書く
    output wire [18:0] cur_bram_addr,
    output wire [7:0]  cur_bram_data,
    output wire        cur_bram_we,

    // prev_data_ram 読み出し
    output wire [16:0] prev_rdaddr,

    // prev_data_ram 書き込み更新
    output reg  [16:0] prev_wraddr,
    output reg  [7:0]  prev_data,
    output reg         prev_wren,

    // 差分画像BRAMへ書き込み
    output reg  [16:0] diff_addr,
    output reg  [7:0]  diff_data,
    output reg         diff_we
);

    // 現在画像BRAMにはそのまま保存
    assign cur_bram_addr = cap_addr;
    assign cur_bram_data = cap_data;
    assign cur_bram_we   = cap_we;

    // 前画像RAMは現在のアドレスで読む
    assign prev_rdaddr = cap_addr[16:0];

    // prev_q は1クロック遅れて出るので、現在画素も遅延させる
    reg [16:0] cap_addr_d1;
    reg [7:0]  cap_data_d1;
    reg        cap_we_d1;

    always @(posedge pclk or negedge rst_n) begin
        if (!rst_n) begin
            cap_addr_d1 <= 17'd0;
            cap_data_d1 <= 8'd0;
            cap_we_d1   <= 1'b0;

            diff_addr   <= 17'd0;
            diff_data   <= 8'd0;
            diff_we     <= 1'b0;

            prev_wraddr <= 17'd0;
            prev_data   <= 8'd0;
            prev_wren   <= 1'b0;
        end else begin
            // 1クロック遅延
            cap_addr_d1 <= cap_addr[16:0];
            cap_data_d1 <= cap_data;
            cap_we_d1   <= cap_we;

            diff_we   <= cap_we_d1;
            diff_addr <= cap_addr_d1;

            if (cap_data_d1 > prev_q)
                diff_data <= cap_data_d1 - prev_q;
            else
                diff_data <= prev_q - cap_data_d1;

            // 次回比較用に、現在画素をprev_data_ramへ保存
            prev_wren   <= cap_we_d1;
            prev_wraddr <= cap_addr_d1;
            prev_data   <= cap_data_d1;
        end
    end

endmodule